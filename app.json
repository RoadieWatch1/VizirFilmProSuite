{
  "expo": {
    "name": "VizirFilmProSuite",
    "slug": "vizirfilmsprosuite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vizirfilmsuite",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0d3b3c"
    },
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "apiKey": "${EXPO_PUBLIC_OPENAI_API_KEY}"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
